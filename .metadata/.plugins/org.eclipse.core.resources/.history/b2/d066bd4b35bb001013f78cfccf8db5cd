  MX_GPIO_Init();
  MX_USART2_UART_Init();
  MX_SPI1_Init();
  MX_FDCAN2_Init();
  /* USER CODE BEGIN 2 */
  HAL_GPIO_WritePin(ENC_CS_GPIO_Port, ENC_CS_Pin, GPIO_PIN_SET);
  uint16_t angle = 0;

  HAL_GPIO_WritePin(LED2_GPIO_Port, LED2_Pin, GPIO_PIN_RESET);

  // start DRV
  HAL_GPIO_WritePin(MOTOR_ENABLE_GPIO_Port, MOTOR_ENABLE_Pin, GPIO_PIN_SET);
  HAL_Delay(50);

  BitbangSPI_Init(&spi, &opts);
  uint16_t input_val = (DCR<<11) | (0x0<<9) | (0x0<<8) | (0x0<<7) | (0x1<<5) | (0x0<<4) | (0x0<<3) | (0x0<<2) | (0x0<<1) | 0x1;

  uint16_t val = drv_spi_write(&spi, input_val);     
  //= BitbangSPI_Write(&spi, input_val);

  printf("val = %u\n\r", val);

  uint16_t addr = (DCR<<11);
  val = drv_spi_write(&spi, input_val);
  printf("val = %u\n\r", val);
  val = BitbangSPI_Read(&spi, addr);
  printf("val = %u\n\r", val);


  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  {
	  angle = readMagAlphaAngle();
	  float angleDeg = ((float)angle / 65536.0f) * 360.0f;
	  uint16_t angleInt = (uint16_t) angleDeg;
	  printf("Angle = %u\n\r", angleInt);
	  HAL_Delay(1000);
    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */
  }
  /* USER CODE END 3 */
}

