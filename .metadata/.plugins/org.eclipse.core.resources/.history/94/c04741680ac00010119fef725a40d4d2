#include "pwm_util.h"
#include "tim.h"
#include "stdio.h"

/**
 * Move of setPwmFreqency from main.c. This updates TIM2 ARR and forces
 * an update so the new period takes effect immediately. It also bounds
 * the ARR to 16-bit to avoid overflow on typical timers.
 */
void setPwmFreqency(float desiredPwmFrequencyHz)
{
    if (desiredPwmFrequencyHz <= 0.0f) {
        printf("Invalid pwm frequency: %f\n\r", desiredPwmFrequencyHz);
        return;
    }

    /* original code used 170 MHz as clock - keep that constant for now */
    const float timerClockHz = 170000000.0f;

    float pwmPeriod = 1.0f / desiredPwmFrequencyHz;
    float timerTickPeriod = 1.0f / timerClockHz;

    /* Preserve original division by 2.0 (kept from previous code) */
    uint32_t arr = (uint32_t)(pwmPeriod / (2.0f * timerTickPeriod));
    if (arr == 0) arr = 1;
    if (arr > 0xFFFFu) arr = 0xFFFFu; /* bound to 16-bit ARR */

    __HAL_TIM_SET_AUTORELOAD(&htim2, arr);
    __HAL_TIM_SET_COUNTER(&htim2, 0);
    __HAL_TIM_FORCE_UPDATE(&htim2);

    printf("setPwmFreqency: desired %f Hz -> ARR=%lu\n\r", desiredPwmFrequencyHz, (unsigned long)__HAL_TIM_GET_AUTORELOAD(&htim2));
}
